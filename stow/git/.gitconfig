[core]
	quotepath = false
	editor = vim
[user]
	email = minstrike520@gmail.com
	name = minstrike520
[credential "https://github.com"]
	helper =
	helper = !$PREFIX/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !$PREFIX/bin/gh auth git-credential
[safe]
	directory = /storage/emulated/0/Documents/Obsidian/StudyingSpace_Phone
	directory = /storage/emulated/0/Documents/Obsidian/vault-v5
[alias]
	d = diff
	l = log --oneline --decorate --all --graph
	lg = log --oneline --decorate --all --graph
	st = status
	ls = status
	cm = commit -m
	a = add
	aa = add .
[credential "http://gitea.rpi.local"]
	helper = 
	helper = !tea login helper
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential "https://gitlab.taieol.tw"]
	helper = 
	helper = !/usr/bin/glab auth git-credential
